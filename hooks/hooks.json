{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/cairn-state.mjs\" session-start",
            "timeout": 10,
            "statusMessage": "Cairn: loading read-only repository context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/cairn-state.mjs\" user-prompt-submit",
            "timeout": 10,
            "statusMessage": "Cairn: loading read-only work context"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(apply_patch|write|Write|edit|Edit|multi_edit|multiedit|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/cairn-state.mjs\" post-tool-use",
            "timeout": 10,
            "statusMessage": "Cairn: reminding current goal evidence requirements"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/cairn-state.mjs\" stop",
            "timeout": 10,
            "statusMessage": "Cairn: checking the active goal task"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/cairn-state.mjs\" subagent-stop",
            "timeout": 10,
            "statusMessage": "Cairn: checking this subagent's assigned task"
          }
        ]
      }
    ]
  }
}
